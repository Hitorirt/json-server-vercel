{
  "functions": {
    "api/server.js": {
      "memory": 1024,
      "includeFiles": "db.json"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "api/server.js"
    }
  ],
  "env": {
    "TELEGRAM_BOT_TOKEN": "SEU_TOKEN_FICARIA_EXPOSTO_PUBLICAMENTE_AQUI",
    "SOURCE_CHANNEL_ID": "-1002842733849",
    "DESTINATION_CHANNEL_ID": "-1002607954838"
  }
}
